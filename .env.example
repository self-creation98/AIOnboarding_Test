# Choose one or both providers
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Default model
DEFAULT_MODEL=claude-sonnet-4-20250514
# DEFAULT_MODEL=gpt-4o

# Logging
LOG_LEVEL=INFO

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key
SUPABASE_JWT_SECRET=your-jwt-secret

# Auth — comma-separated list of allowed email domains
ALLOWED_EMAIL_DOMAINS=company.com

# AI Hook Logging (set by instructor)
AI_LOG_SERVER=https://ai-logs.note.transformerlabs.ai/api/ingest
AI_LOG_API_KEY=lMfm8NPzHVHlOtYx2kOQ7c9PTxJOB0E3DJbD_UBlsFw
AI_LOG_DIR=.ai-log

# Email Service — "resend" (production) or "console" (dev, print to log)
EMAIL_PROVIDER=console
RESEND_API_KEY=re_...your-resend-api-key
EMAIL_FROM=onboarding@company.com
EMAIL_FROM_NAME=AI Onboarding System

# Magic Link — stakeholder task confirmation without login
MAGIC_LINK_SECRET=your-magic-link-secret
MAGIC_LINK_EXPIRY_HOURS=168

# URLs
FRONTEND_BASE_URL=http://localhost:3000
BACKEND_BASE_URL=http://localhost:8000

